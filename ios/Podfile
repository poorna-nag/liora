# Firebase SDK 12.x (cloud_firestore/auth/etc.) requires iOS 15.0+.
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# Workaround for an ar_flutter_plugin_engine packaging bug: it ships its iOS
# podspec as `ar_flutter_plugin.podspec` with `s.name = 'ar_flutter_plugin'`,
# which doesn't match the pub package name, so `pod install` fails with
# "No podspec found for ar_flutter_plugin_engine". We generate a correctly named
# podspec next to it before Flutter installs the plugin pods. Runs on every
# `flutter run`/`pod install`, so it survives clean checkouts.
ar_plugin_ios = File.expand_path(File.join('.symlinks', 'plugins', 'ar_flutter_plugin_engine', 'ios'), __dir__)
ar_src = File.join(ar_plugin_ios, 'ar_flutter_plugin.podspec')
ar_dst = File.join(ar_plugin_ios, 'ar_flutter_plugin_engine.podspec')
if File.exist?(ar_src)
  spec = File.read(ar_src)
    .gsub(/s\.name\s*=\s*'ar_flutter_plugin'/, "s.name             = 'ar_flutter_plugin_engine'")
    # ARCore 1.33 pins an old nanopb that clashes with Firebase's nanopb 3.x.
    # We don't use cloud anchors, so allow a newer ARCore that's compatible.
    .gsub(/'ARCore\/CloudAnchors',\s*'~> 1\.33\.0'/, "'ARCore/CloudAnchors', '>= 1.36.0'")
  File.write(ar_dst, spec) unless File.exist?(ar_dst) && File.read(ar_dst) == spec
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

      # permission_handler compiles permission handlers behind preprocessor
      # macros; enable the ones the app actually requests (camera/AR, mic,
      # speech, photos, notifications) so they link correctly.
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_CAMERA=1',
        'PERMISSION_MICROPHONE=1',
        'PERMISSION_SPEECH_RECOGNIZER=1',
        'PERMISSION_PHOTOS=1',
        'PERMISSION_NOTIFICATIONS=1',
      ]
    end
  end
end
